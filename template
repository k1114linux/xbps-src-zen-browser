do_install() {
		# Install the files
		vmkdir usr/lib/zen-browser
		vcopy * usr/lib/zen-browser

		# link the binary
		vmkdir usr/bin/
		ln -s /usr/lib/zen-browser/zen ${DESTDIR}/usr/bin/
}

# Add the necessary dependencies if there are any
